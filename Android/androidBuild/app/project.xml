<project>
    <!-- APP CONFIG -->
    <app title="Spritemap to Funky"
         file="SpritemaptoFunky"
         package="com.thejarretlabs.spritemaptofunky"
         version="1.0.0"
         company="JarretLabs"
         main="Main" />

    <if target="android">
    <android extension="org.haxe.extension.AndroidFilePicker" />
    <android minimum-sdk-version="16" target-sdk-version="33" />
    <window width="720" height="1280"
            fps="60"
            background="#050816"
            orientation="portrait"
            fullscreen="false" />

    <icon path="assets/icons/iconOG.png" />

    <permission name="android.permission.READ_EXTERNAL_STORAGE" />
    <permission name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <permission name="android.permission.READ_MEDIA_IMAGES" />
    <permission name="android.permission.READ_MEDIA_VIDEO" />
    <permission name="android.permission.READ_MEDIA_AUDIO" />
</if>

    <source path="src" />
    <java path="android/java" if="android" />
    <assets path="assets" />

    <haxelib name="openfl" />
    <haxelib name="lime" />
    <haxelib name="hxzip" /> <!-- para guardar spritemap procesado -->

</project>