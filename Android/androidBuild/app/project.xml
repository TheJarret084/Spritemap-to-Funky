<project>
    <!-- APP CONFIG -->
    <app title="Spritemap to Funky"
         file="SpritemaptoFunky"
         package="com.thejarretlabs.spritemaptofunky"
         version="1.0.0"
         company="JarretLabs"
         main="Main" />

    <window width="720" height="1280"
            fps="60"
            background="#111827"
            orientation="portrait" />

    <!-- SOURCE -->
    <source path="src" />

    <!-- ASSETS -->
    <assets path="assets" />

    <!-- ICON -->
    <icon path="assets/icons/iconOG.png" />

    <!-- LIBS -->
    <haxelib name="openfl" />
    <haxelib name="lime" />

    <!-- ========================= -->
    <!-- BACKEND NATIVO -->
    <!-- ========================= -->

    <!-- Linux -->
    <if target="linux">
        <ndll name="backend" />
    </if>

    <!-- Android -->
    <if target="android">
        <ndll name="backend" />
    </if>

</project>