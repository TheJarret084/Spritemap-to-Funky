<project>
    <!-- APP CONFIG -->
    <app title="Spritemap to Funky"
         file="SpritemaptoFunky"
         package="com.thejarretlabs.spritemaptofunky"
         version="1.0.0"
         company="JarretLabs"
         main="Main" />

    <!-- ========================= -->
    <!-- WINDOWS / RESOLUCIÓN -->
    <!-- ========================= -->

    <!-- Linux -->
    <if target="linux">
        <window width="720" height="1280"
                fps="30"
                background="#111827"
                resizable="true" />
        
        <icon path="assets/icons/icon.png" />
    </if>

    <!-- Android -->
    <if target="android">
        <window width="720" height="1280"
                fps="60"
                background="#111827"
                orientation="portrait"
                fullscreen="false" />
<!--JARRET PORQUE EN FALSE????, porque la mierda se rompe en pantalla, usuario ignorante-->
        
        <icon path="assets/icons/iconOG.png" />
    </if>

    <!-- ========================= -->
    <!-- SOURCE -->
    <!-- ========================= -->

    <source path="src" />
    <assets path="assets" />

    <!-- LIBS -->
    <haxelib name="openfl" />
    <haxelib name="lime" />

    <!-- BACKEND -->
    <if target="linux || android">
        <ndll name="backend" />
    </if>

</project>