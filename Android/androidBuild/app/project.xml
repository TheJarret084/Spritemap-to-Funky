<project>
    <!-- APP CONFIG -->
    <app title="Spritemap to Funky"
         file="SpritemaptoFunky"
         package="com.thejarretlabs.spritemaptofunky"
         version="1.0.0"
         company="JarretLabs"
         main="Main" />

    <!-- <define name="caros" if="debug && android" /> -->

    <if target="android">
        <android extension="org.haxe.extension.AndroidFilePicker" />
        <android minimum-sdk-version="16" target-sdk-version="33" />
        <architecture name="armv7" />
        <architecture name="arm64" />

        <window width="720" height="1280"
                fps="60"
                background="#050816"
                orientation="portrait"
                fullscreen="false" />

        <icon path="iconAndroid.png" />
        

        <permission name="android.permission.READ_EXTERNAL_STORAGE" />
    </if>

    <source path="src" />
    <java path="android/java" if="android" />
    <!-- ASSETS -->
    <assets path="assets" rename="assets" />

    <haxelib name="openfl" />
    <haxelib name="lime" />
    <haxelib name="hxdiscord_rpc" />

</project>
