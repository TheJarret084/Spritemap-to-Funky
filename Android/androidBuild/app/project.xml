<project>
    <!-- APP CONFIG -->
    <app title="Spritemap to Funky"
         file="SpritemaptoFunky"
         package="com.thejarretlabs.spritemaptofunky"
         version="1.0.0"
         company="JarretLabs"
         main="Main" />

    <if target="android">
        <android extension="org.haxe.extension.AndroidFilePicker" />
        <android minimum-sdk-version="16" target-sdk-version="33" />

        <window width="720" height="1280"
                fps="60"
                background="#050816"
                orientation="portrait"
                fullscreen="false" />

        <icon path="assets/icons/iconOG.png" />

        <permission name="android.permission.READ_EXTERNAL_STORAGE" />
    </if>

    <source path="src" />
    <java path="android/java" if="android" />

    <!-- Assets: solo lo necesario para la app (no outputs ni carpetas de trabajo) -->
    <assets path="assets/buttons" rename="buttons" />
    <assets path="assets/icons"   rename="icons"   />
    <assets path="assets/other"   rename="other"   />

    <haxelib name="openfl" />
    <haxelib name="lime" />

</project>